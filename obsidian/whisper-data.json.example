{
  "apiKey": "",
  "openAiApiKey": "",
  "anthropicApiKey": "",
  "postProcessingApiKey": "",
  "apiUrl": "http://127.0.0.1:50062/v1/audio/transcriptions",
  "model": "whisper-1",
  "language": "",
  "prompt": "",
  "temperature": 0,
  "responseFormat": "json",
  "cursorContext": false,
  "audioDeviceId": "default",
  "saveAudioFile": true,
  "audioSavePath": "Voice Notes/audio",
  "createNoteFile": true,
  "noteSavePath": "Voice Notes",
  "noteFilenameTemplate": "{{title}}",
  "noteTemplate": "# {{title}}\n\n> Recorded {{datetime}}\n\n![[{{audioFile}}]]\n\n{{transcription}}",
  "debugMode": false,
  "postProcessing": true,
  "postProcessingProvider": "custom",
  "postProcessingUrl": "http://127.0.0.1:11434/v1/chat/completions",
  "postProcessingModel": "gemma4:e4b-mlx",
  "postProcessingPrompt": "You format raw voice-note transcripts into clean Obsidian markdown. Output only valid GitHub-flavored Markdown - no preamble, no commentary, no code fences around the whole response. Produce, in order: ## Summary (1-2 sentences). ## Tasks (action items as '- [ ] ' checkboxes; omit the section entirely if none; do not invent tasks). ## Notes (key points as bullets). ## Transcript (the verbatim transcript). Do not add facts not present in the transcript.",
  "autoGenerateTitle": true,
  "titleGenerationPrompt": "Generate a short title (1-5 words) for the following text. Return only the title, nothing else.",
  "keepOriginalTranscription": false
}